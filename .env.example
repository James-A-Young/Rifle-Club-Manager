DATABASE_URL=postgresql://shootingmatch:shootingmatch@localhost:5432/shootingmatch
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Frontend Runtime Configuration (served by /api/config at app startup)
# Leave blank for default (relative URLs work for same-origin requests)
VITE_API_URL=

# Cloudflare Turnstile (optional, recommended for signup abuse prevention)
# Set both keys to enable captcha verification on registration.
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=

# Google Analytics (optional)
# Set to your GA4 Measurement ID (e.g. G-XXXXXXXXXX) to enable analytics tracking.
# Leave blank to disable.
VITE_GA_MEASUREMENT_ID=

# Transactional Email (Resend)
# Optional: enables invite delivery and password reset emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Google Wallet API Configuration (for membership cards)
# Leave blank to disable Google Wallet pass issuing
# Get credentials from Google Wallet business account (pay.google.com)
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_ISSUER_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=
GOOGLE_WALLET_PRIVATE_KEY_ID=
GOOGLE_WALLET_PROJECT_ID=

# Google Drive Backup (optional)
# OAuth client used by club admins to link Drive and by worker uploads
# You can also set GOOGLE_DRIVE_CREDS_JSON_PATH to load these values from a Google OAuth client JSON file.
# Explicit GOOGLE_DRIVE_OAUTH_* env vars take precedence over file values.
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=
GOOGLE_DRIVE_CREDS_JSON_PATH=
# 32-byte key for encrypting Drive refresh tokens at rest (raw 32-char or base64 32-byte value)
GOOGLE_DRIVE_TOKEN_ENCRYPTION_KEY=

# Backup Worker schedule (UTC)
BACKUP_SCHEDULE_HOUR_UTC=2
BACKUP_SCHEDULE_JITTER_MS=300000
BACKUP_WORKER_CONCURRENCY=2
BACKUP_RUN_ON_STARTUP=false
