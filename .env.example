DATABASE_URL=postgresql://shootingmatch:shootingmatch@localhost:5432/shootingmatch
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Frontend Runtime Configuration (served by /api/config at app startup)
# Leave blank for default (relative URLs work for same-origin requests)
VITE_API_URL=

# Cloudflare Turnstile (optional, recommended for signup abuse prevention)
# Set both keys to enable captcha verification on registration.
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=

# Google Analytics (optional)
# Set to your GA4 Measurement ID (e.g. G-XXXXXXXXXX) to enable analytics tracking.
# Leave blank to disable.
VITE_GA_MEASUREMENT_ID=

# Google Wallet API Configuration (for membership cards)
# Leave blank to disable Google Wallet pass issuing
# Get credentials from Google Wallet business account (pay.google.com)
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_ISSUER_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=
GOOGLE_WALLET_PRIVATE_KEY_ID=
GOOGLE_WALLET_PROJECT_ID=
