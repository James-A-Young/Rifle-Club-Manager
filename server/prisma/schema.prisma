datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  INACTIVE
}

enum MembershipRole {
  MEMBER
  ADMIN
  PROBATIONARY_MEMBER
  JUNIOR
}

enum OwnerType {
  USER
  CLUB
}

enum BackupDataset {
  SIGN_IN_HISTORY
  SALES_LEDGER
  COMPETITION_RESULTS
}

enum GoogleDriveConnectionStatus {
  ACTIVE
  DISCONNECTED
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  passwordHash    String
  gdprConsentDate DateTime
  address         String
  placeOfBirth    String
  dateOfBirth     DateTime
  firearmCertificateNumber String?
  firearmCertificateExpiry DateTime?
  shotgunCertificateNumber String?
  shotgunCertificateExpiry DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ownedClubs      Club[]
  memberships     ClubMembership[]
  visitLogs       VisitLog[]
  firearms        Firearm[]
  ammunitionSalesAsBuyer  AmmunitionSale[] @relation("AmmunitionSaleBuyer")
  ammunitionSalesAsSeller AmmunitionSale[] @relation("AmmunitionSaleSeller")
  ammunitionStockInputs  AmmunitionStockInput[]
  createdInvites  ClubInvite[] @relation("InviteCreatedBy")
  redeemedInvites ClubInvite[] @relation("InviteRedeemedBy")
  competitionEntries CompetitionEntry[]
  scores             Score[]
  passwordResetTokens PasswordResetToken[]
  linkedGoogleDriveConnections GoogleDriveConnection[] @relation("GoogleDriveLinkedByUser")
}

model Club {
  id                String   @id @default(cuid())
  name              String
  homeOfficeRef     String?
  address           String?
  disciplinesOffered Json?
  acceptingNewMembers Boolean @default(true)
  openingTimes      String?
  description       String?
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id])
  createdAt         DateTime @default(now())

  memberships      ClubMembership[]
  visitLogs        VisitLog[]
  signInLinks      SignInLink[]
  firearms         Firearm[]
  ammunitionTypes       AmmunitionType[]
  ammunitionSafes       AmmunitionSafe[]
  ammunitionStocks      AmmunitionStock[]
  ammunitionSales       AmmunitionSale[]
  ammunitionStockInputs AmmunitionStockInput[]
  invites          ClubInvite[]
  settings         ClubSettings?
  seasons          Season[]
  competitions     Competition[]
  googleDriveConnection GoogleDriveConnection?
  backupJobStates  BackupJobState[]
  backupRuns       BackupRun[]
}

model ClubMembership {
  id        String           @id @default(cuid())
  userId    String
  clubId    String
  status    MembershipStatus @default(PENDING)
  role      MembershipRole   @default(MEMBER)
  expiresAt DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
  club Club @relation(fields: [clubId], references: [id])

  @@unique([userId, clubId])
}

model Firearm {
  id           String    @id @default(cuid())
  make         String
  model        String
  caliber      String
  serialNumber String
  ownerType    OwnerType
  userId       String?
  clubId       String?
  createdAt    DateTime  @default(now())

  user      User?      @relation(fields: [userId], references: [id])
  club      Club?      @relation(fields: [clubId], references: [id])
  visitLogs VisitLog[]

  @@index([serialNumber])
}

model VisitLog {
  id              String    @id @default(cuid())
  publicVisitRef  String?   @unique @default(cuid())
  userId          String?
  clubId          String
  purpose         String
  guestName       String?
  guestEmail      String?
  guestClubRepresented String?
  firearmUsedId   String?
  timeIn          DateTime  @default(now())
  timeOut         DateTime?
  createdAt       DateTime  @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  club        Club     @relation(fields: [clubId], references: [id])
  firearmUsed Firearm? @relation(fields: [firearmUsedId], references: [id])

  @@index([clubId, timeIn])
  @@index([clubId, userId, timeIn])
  @@index([clubId, firearmUsedId, timeIn])
}

model SignInLink {
  id          String   @id @default(cuid())
  clubId      String
  cryptoToken String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id])
}

model ClubInvite {
  id               String         @id @default(cuid())
  clubId           String
  email            String
  role             MembershipRole
  token            String         @unique
  expiresAt        DateTime
  redeemedAt       DateTime?
  redeemedByUserId String?
  createdByUserId  String
  createdAt        DateTime       @default(now())

  club       Club  @relation(fields: [clubId], references: [id])
  createdBy  User  @relation("InviteCreatedBy", fields: [createdByUserId], references: [id])
  redeemedBy User? @relation("InviteRedeemedBy", fields: [redeemedByUserId], references: [id])

  @@index([clubId, createdAt])
  @@index([clubId, email])
  @@index([email])
}

model PasswordResetToken {
  id                String   @id @default(cuid())
  userId            String
  token             String   @unique
  expiresAt         DateTime
  usedAt            DateTime?
  usedByIp          String?
  usedByUserAgent   String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model ClubSettings {
  id                       String   @id @default(cuid())
  clubId                   String   @unique
  logoUrl                  String?
  primaryColor             String?  @default("#1f2937")
  secondaryColor           String?  @default("#374151")
  accentColor              String?  @default("#3b82f6")
  passIssuingEnabled       Boolean  @default(false)
  memberCardSignInEnabled  Boolean  @default(false)
  backupEnabled            Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model GoogleDriveConnection {
  id                      String   @id @default(cuid())
  clubId                  String   @unique
  linkedByUserId          String
  status                  GoogleDriveConnectionStatus @default(ACTIVE)
  driveFolderId           String?
  encryptedRefreshToken   String
  tokenIv                 String
  tokenAuthTag            String
  tokenScope              String?
  tokenExpiry             DateTime?
  linkedAt                DateTime @default(now())
  disconnectedAt          DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  club        Club  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  linkedBy    User  @relation("GoogleDriveLinkedByUser", fields: [linkedByUserId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([linkedAt])
}

model BackupJobState {
  id                    String       @id @default(cuid())
  clubId                String
  dataset               BackupDataset
  monthStartUtc         DateTime
  lastSourceFingerprint String
  driveFileId           String?
  lastSuccessAt         DateTime?
  lastRunDurationMs     Int?
  lastError             String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, dataset, monthStartUtc])
  @@index([clubId, dataset])
  @@index([lastSuccessAt])
}

model BackupRun {
  id             String   @id @default(cuid())
  clubId         String
  dataset        BackupDataset
  monthStartUtc  DateTime
  status         String
  sourceFingerprint String?
  driveFileId    String?
  durationMs     Int?
  error          String?
  startedAt      DateTime @default(now())
  finishedAt     DateTime?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, startedAt])
  @@index([dataset, monthStartUtc])
}

model GoogleDriveOAuthState {
  id          String   @id @default(cuid())
  state       String   @unique
  clubId      String
  userId      String
  nonce       String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([clubId, userId])
  @@index([expiresAt])
}

model AmmunitionType {
  id                String   @id @default(cuid())
  clubId            String
  name              String
  currentPricePence Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  club         Club                          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  priceHistory AmmunitionTypePriceHistory[]
  stocks       AmmunitionStock[]
  sales        AmmunitionSale[]
  stockInputs  AmmunitionStockInput[]

  @@unique([clubId, name])
  @@index([clubId, createdAt])
}

model AmmunitionTypePriceHistory {
  id               String   @id @default(cuid())
  ammunitionTypeId String
  pricePence       Int
  createdAt        DateTime @default(now())

  ammunitionType AmmunitionType @relation(fields: [ammunitionTypeId], references: [id], onDelete: Cascade)

  @@index([ammunitionTypeId, createdAt])
}

model AmmunitionSafe {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club        Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  stocks      AmmunitionStock[]
  sales       AmmunitionSale[]
  stockInputs AmmunitionStockInput[]

  @@unique([clubId, name])
  @@index([clubId, createdAt])
}

model AmmunitionStock {
  id               String   @id @default(cuid())
  clubId           String
  ammunitionTypeId String
  ammunitionSafeId String
  quantity         Int      @default(0)
  updatedAt        DateTime @updatedAt

  club           Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  ammunitionType AmmunitionType @relation(fields: [ammunitionTypeId], references: [id], onDelete: Cascade)
  ammunitionSafe AmmunitionSafe @relation(fields: [ammunitionSafeId], references: [id], onDelete: Cascade)

  @@unique([ammunitionTypeId, ammunitionSafeId])
  @@index([clubId])
}

model AmmunitionSale {
  id                String   @id @default(cuid())
  clubId            String
  buyerFirstName    String
  buyerLastName     String
  buyerUserId       String?
  soldByUserId      String
  ammunitionTypeId  String
  ammunitionSafeId  String
  quantity          Int
  unitPricePence    Int
  totalPricePence   Int
  createdAt         DateTime @default(now())

  club           Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  buyer          User?          @relation("AmmunitionSaleBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  soldBy         User           @relation("AmmunitionSaleSeller", fields: [soldByUserId], references: [id], onDelete: Restrict)
  ammunitionType AmmunitionType @relation(fields: [ammunitionTypeId], references: [id], onDelete: Restrict)
  ammunitionSafe AmmunitionSafe @relation(fields: [ammunitionSafeId], references: [id], onDelete: Restrict)

  @@index([clubId, createdAt])
  @@index([clubId, buyerUserId, createdAt])
  @@index([clubId, soldByUserId, createdAt])
}

model Season {
  id         String   @id @default(cuid())
  clubId     String
  name       String
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  competitions Competition[]

  @@unique([clubId, name])
  @@index([clubId, createdAt])
}

model Competition {
  id              String   @id @default(cuid())
  clubId          String
  seasonId        String
  name            String
  organiser       String?
  roundCount      Int
  cardsPerRound   Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  club    Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season  Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  rounds  Round[]
  entries CompetitionEntry[]
  scores  Score[]

  @@unique([seasonId, name])
  @@index([clubId, createdAt])
}

model Round {
  id            String   @id @default(cuid())
  competitionId String
  roundNumber   Int
  dueDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  scores      Score[]

  @@unique([competitionId, roundNumber])
  @@index([competitionId, dueDate])
}

model CompetitionEntry {
  id            String   @id @default(cuid())
  competitionId String
  userId        String
  createdAt     DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([competitionId, userId])
  @@index([userId])
}

model Score {
  id            String   @id @default(cuid())
  competitionId String
  roundId       String
  userId        String
  cardNumber    Int
  score         Int?
  updatedAt     DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  round       Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId, cardNumber])
  @@index([userId])
  @@index([roundId])
  @@index([competitionId])
}

model AmmunitionStockInput {
  id               String   @id @default(cuid())
  clubId           String
  ammunitionTypeId String
  ammunitionSafeId String
  quantity         Int
  note             String?
  inputByUserId    String
  createdAt        DateTime @default(now())

  club           Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  ammunitionType AmmunitionType @relation(fields: [ammunitionTypeId], references: [id], onDelete: Restrict)
  ammunitionSafe AmmunitionSafe @relation(fields: [ammunitionSafeId], references: [id], onDelete: Restrict)
  inputBy        User           @relation(fields: [inputByUserId], references: [id], onDelete: Restrict)

  @@index([clubId, createdAt])
}
